# ═══════════════════════════════════════════════════════════════════
# API 测试平台 Demo — 环境配置模板
# ═══════════════════════════════════════════════════════════════════
# 使用方法: 复制为 .env，填入你的 API Key
#   cp .env.example .env
#
# 零配置也能跑！不填任何 Key 也能走降级路径跑通全链路。
# ═══════════════════════════════════════════════════════════════════

# ── 应用基础 ──
APP_NAME=API接口智能测试系统-Demo
DEBUG=true

# ── Docker 服务连接 ──
# 端口与 docker-compose.yml 宿主机映射一致
MYSQL_HOST=localhost
MYSQL_PORT=3309
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=api_test

REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456789

# ── LLM API Keys (可选, 不填则自动降级) ──
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 阿里云 DashScope: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus

EMBEDDING_MODEL=text-embedding-v3
RERANKER_MODEL=qwen3-rerank

# ── 运行模式 ──
# auto=自动检测 | force_local=强制离线 | force_real=强制真实服务
DEMO_MODE=auto
